generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Claim {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  status      String   @default("open")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  claims    Claim[]
}